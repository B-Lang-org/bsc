{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "bluespec",
      "camelcase": "Bluespec",
      "title": "Bluespec",
      "scope": "source.bluespec",
      "file-types": [
        "bluespec"
      ],
      "injection-regex": "^bluespec$",
      "class-name": "TreeSitterBluespec"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "BSD-3-Clause",
    "description": "The Bluespec hardware design language (classic syntax)",
    "authors": [
      {
        "name": "Mieszko Lis"
      }
    ]
  },
  "bindings": {
    "c": false,
    "go": false,
    "java": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
