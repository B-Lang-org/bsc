-- Test that PrimStringSplit produces correctly-typed results
-- when checked with -trace-eval-types

package StringSplitTypes where

{-# synthesize sysStringSplitTypes #-}
sysStringSplitTypes :: Module Empty
sysStringSplitTypes = module
   -- non-empty string exercises the Valid result path
   rg :: Reg Bool
   rg <- mkReg (isJust (stringSplit "hello"))
   -- empty string exercises the Invalid result path
   rg2 :: Reg Bool
   rg2 <- mkReg (isJust (stringSplit ""))
