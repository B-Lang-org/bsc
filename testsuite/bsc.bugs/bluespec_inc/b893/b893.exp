# BSC used to disable aggressive-conditions entirely inside a method,
# rather than only when the condition contains an argument of the method.
# This tests that BSC does lift inside a method when possible.

if {$vtest == 1} {
    compile_verilog_pass Bug893.bsv {} {-aggressive-conditions}
    find_n_strings sysBug893.v {assign RDY_get = r ? f1$EMPTY_N : f2$EMPTY_N ;} 1
}
