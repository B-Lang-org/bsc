package ATFKindNum where

-- Test ATF with numeric kind (#).
-- The equation Width Bool = 1 must be expanded so that
-- encode :: Bool -> Bit (Width Bool) becomes Bool -> Bit 1.

class FixedWidth f where
  type Width f :: #
  encode :: f -> Bit (Width f)

instance FixedWidth Bool where
  type Width Bool = 1
  encode b = pack b

-- Verify that the result type is exactly Bit 1 after expansion.
result :: Bit 1
result = encode True
