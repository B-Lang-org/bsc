package ATFImported where

import ATFImportedLib

-- Test that ATF equations from an imported package are visible to the
-- type checker.  The equation  type Elem (Box a) = a  is defined in
-- ATFImportedLib.  The typechecker must expand it here to verify that
-- extractBox has type Box Integer -> Integer.

extractBox :: Box Integer -> Integer
extractBox = extract

test :: Integer
test = extractBox (Box 42)
